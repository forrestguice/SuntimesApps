s": {"9b3c7b37d0e3b44f39c6d286100c2b5bd662ef87e422b44b8b0f762dbc683722": {"added": 1782289793000, "file": {"name": "/com.forrestguice.suntimes.mappack_1.apk", "sha256": "9b3c7b37d0e3b44f39c6d286100c2b5bd662ef87e422b44b8b0f762dbc683722", "size": 29464177}, "manifest": {"versionName": "0.1.0", "versionCode": 1, "usesSdk": {"minSdkVersion": 16, "targetSdkVersion": 36}, "signer": {"sha256": ["65bb24f4fba912912a9e86e51c0901b9f7fc8ec886ae6f7149c312e03c4e9480"]}, "usesPermission": [{"name": "suntimes.permission.READ_CALCULATOR"}, {"name": "com.forrestguice.suntimes.mappack.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"}]}, "whatsNew": {"en-US": "- initial release"}}}}, "com.forrestguice.suntimes.naturalhour": {"metadata": {"changelog": "https://github.com/forrestguice/NaturalHour/blob/HEAD/CHANGELOG.md", "lastUpdated": 1749017819000, "screenshots": {"phone": {"en-US": [{"name": "/com.forrestguice.suntimes.naturalhour/en-US/phoneScreenshots/1.png", "sha256": "7641d5e393b1c5eb1d26d0d691d4d10573dcf9b1ba98ac068660e922dbf3de84", "size": 55760}, {"name": "/com.forrestguice.suntimes.naturalhour/en-US/phoneScreenshots/2.png", "sha256": "8a378e1419ad73fb5d1d0b49d1ae4381641503fc1841b500980b0fb7efbb3852", "size": 52559}, {"name": "/com.forrestguice.suntimes.naturalhour/en-US/phoneScreenshots/3.png", "sha256": "ccc8e9b92d9b3bbf2bc2709e38d5d248a38e693b46dfe7bb567afea1d777972d", "size": 51054}, {"name": "/com.forrestguice.suntimes.naturalhour/en-US/phoneScreenshots/4.png", "sha256": "a08f325b5194b512c6fb8d342caf2a19a0e87c9e515c6f7b62355b10c613ef71", "size": 56668}]}}, "summary": {"en-US": "A 24-hour clock and Roman timekeeping add-on for Suntimes."}, "description": {"en-US": "A 24-hour clock and Roman timekeeping add-on for Suntimes. This app displays the roman hours for a given date and location.\n\nThis is an add-on for Suntimes. It depends on <a href=\"https://f-droid.org/en/packages/com.forrestguice.suntimeswidget/\">Suntimes v0.10.3</a> or later.\n\n* A 24-hr clock face with roman timekeeping divisions; hours, twilights, and night watches.\n* Repeating alarms and notifications (requires Suntimes v0.14.0 or later).\n* Home screen widgets (resizable 3x2, 4x3, and 5x3 clock widgets).\n* The app announces the current time (and roman hour) when the clock is clicked.\n* Quick navigation to the dates of the solstices and equinoxes.\n\nOptions for:\n* hour definitions; the day begins at sunrise/sunset (12), at sunset (24), etc.\n* time zone (support for solar time), and time format (12hr / 24hr)\n* clock orientation; show \"midnight at top\", \"center on noon\".\n* clock numerals; Arabic, Attic, Armenian, Etruscan, Greek, Hebrew, Roman.\n* clock colors (support for custom color schemes).\n\nThe following permissions are required:\n* <small><u>suntimes.permission.READ_CALCULATOR</u></small> is used to read data from the Suntimes provider.\n"}}, "versions": {"51fddeba5e851eb923a3ddf44d06948d3d444f5a63280f25325bd0bc74c3a06b": {"added": 1749017819000, "file": {"name": "/com.forrestguice.suntimes.naturalhour_8.apk", "sha256": "51fddeba5e851eb923a3ddf44d06948d3d444f5a63280f25325bd0bc74c3a06b", "size": 2795723}, "manifest": {"versionName": "0.3.2", "versionCode": 8, "usesSdk": {"minSdkVersion": 14, "targetSdkVersion": 33}, "signer": {"sha256": ["65bb24f4fba912912a9e86e51c0901b9f7fc8ec886ae6f7149c312e03c4e9480"]}, "usesPermission": [{"name": "suntimes.permission.READ_CALCULATOR"}, {"name": "com.forrestguice.suntimes.naturalhour.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"}]}, "whatsNew": {"en-US": "- fixes broken widgets on Android 12+ (#38).\n- fixes bug where alarm activity ignores the \"hour mode\" setting (#38).\n- adds fullscreen behavior; the floating action button is shown for a moment and then hides itself.\n- adds background option to app; \"app theme\" (default), \"black\", \"home screen wallpaper\", \"clock colors\".\n- adds background option to daydream: \"black\" (default), \"clock colors\" (#37).\n- adds daydream options; \"fullscreen\", \"interactive\", \"screen bright\", and \"background pulse\".\n"}}}}, "com.forrestguice.suntimes.nfc": {"metadata": {"changelog": "https://github.com/forrestguice/SuntimesNFC/blob/HEAD/CHANGELOG.md", "lastUpdated": 1762709872000, "webSite": "https://forrestguice.github.io/Suntimes", "donate": ["https://forrestguice.github.io/Suntimes/donate"]}, "versions": {"8762766a4e6452d664bbe20657b768a1975ef4636c89cbe5b4bab6a65baf85dd": {"added": 1762709872000, "file": {"name": "/com.forrestguice.suntimes.nfc_3.apk", "sha256": "8762766a4e6452d664bbe20657b768a1975ef4636c89cbe5b4bab6a65baf85dd", "size": 4892609}, "manifest": {"versionName": "0.1.2", "versionCode": 3, "features": [{"name": "android.hardware.nfc"}], "usesSdk": {"minSdkVersion": 16, "targetSdkVersion": 33}, "signer": {"sha256": ["65bb24f4fba912912a9e86e51c0901b9f7fc8ec886ae6f7149c312e03c4e9480"]}, "usesPermission": [{"name": "suntimes.permission.READ_CALCULATOR"}, {"name": "android.permission.VIBRATE"}, {"name": "android.permission.NFC"}, {"name": "com.forrestguice.suntimes.nfc.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"}]}, "whatsNew": {"en-US": "- fixes bug where NFC tags cannot be scanned on Android 12+.\n- adds themed app icon (Android 13+).\n- adds \"online help\" button."}}}}, "com.forrestguice.suntimes.solunar": {"metadata": {"changelog": "https://github.com/forrestguice/SolunarPeriods/blob/HEAD/CHANGELOG.md", "lastUpdated": 1781847642000, "webSite": "https://forrestguice.github.io/Suntimes", "donate": ["https://forrestguice.github.io/Suntimes/donate"]}, "versions": {"b939befb5db2ba590c5ad45e2176ff190d780fc4a54cb0ec00f00db5b8d2660e": {"added": 1781847642000, "file": {"name": "/com.forrestguice.suntimes.solunar_4.apk", "sha256": "b939befb5db2ba590c5ad45e2176ff190d780fc4a54cb0ec00f00db5b8d2660e", "size": 4743359}, "manifest": {"versionName": "0.2.2", "versionCode": 4, "usesSdk": {"minSdkVersion": 14, "targetSdkVersion": 34}, "signer": {"sha256": ["65bb24f4fba912912a9e86e51c0901b9f7fc8ec886ae6f7149c312e03c4e9480"]}, "usesPermiss